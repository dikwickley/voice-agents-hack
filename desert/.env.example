# ── Swarm (required on desert image) ─────────────────────────────────────
# HTTP base URL of the bootstrap server (see Dockerfile.bootstrap).
DESERT_BOOTSTRAP_URL=http://127.0.0.1:8090

# libp2p TCP port (same default everywhere; each container has its own IP).
DESERT_P2P_LISTEN_PORT=4001

# Optional: multiaddr other peers should use to dial *this* node.
# On Docker Compose with service name `bootstrap`:
#   DESERT_P2P_ANNOUNCE_ADDR=/dns4/bootstrap/tcp/4001
# Native:
#   DESERT_P2P_ANNOUNCE_ADDR=/ip4/127.0.0.1/tcp/4001
# DESERT_P2P_ANNOUNCE_ADDR=

# ── Bootstrap image only ────────────────────────────────────────────────
BOOTSTRAP_HTTP_PORT=8090
BOOTSTRAP_HTTP_HOST=0.0.0.0
# Native-only (all processes on host). Never use with desert in other containers.
# BOOTSTRAP_INCLUDE_LOOPBACK=1

# ── Worker / inference (desert image) ───────────────────────────────────
# Local default: Gemma 4 E2B-it (natively multimodal: text + audio). Shared
# with the orchestrator /voice dictation path so one mmap'd weights dir
# serves both. Cloud fallback on by default (Gemini when local fails).
# Download once with: cd desert/cactus && cactus download google/gemma-4-E2B-it
HF_TOKEN=
DESERT_MOCK=0
DESERT_LLM_MODEL_ID=google/gemma-4-E2B-it
DESERT_ASR_MODEL=openai/whisper-base
DESERT_SILENCE_SEC=1.8
DESERT_DISABLE_TTS=1

GEMINI_API_KEY=
DESERT_CLOUD_FALLBACK=1
DESERT_GEMINI_MODEL=gemini-3-flash-preview

# WEB_SEARCH_PROVIDER=ddg
# TAVILY_API_KEY=
