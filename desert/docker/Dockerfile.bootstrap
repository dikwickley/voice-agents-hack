# syntax=docker/dockerfile:1
#
# Desert bootstrap: libp2p peer + HTTP GET /v1/bootstrap (no Cactus / LLM).
# Build from repo root:
#   docker build -f desert/docker/Dockerfile.bootstrap -t desert-bootstrap:latest .
#
# Docker (default): /v1/bootstrap omits 127.0.0.1 so workers in other containers
# dial the bridge IP (e.g. 172.17.x.x), not themselves.
# Native-only on one host: add -e BOOTSTRAP_INCLUDE_LOOPBACK=1 and optional
#   DESERT_P2P_ANNOUNCE_ADDR=/ip4/127.0.0.1/tcp/4001
#
# On Docker Compose with service name ``bootstrap``:
#   DESERT_P2P_ANNOUNCE_ADDR=/dns4/bootstrap/tcp/4001

FROM python:3.12-slim-bookworm

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        libgmp-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
ENV PYTHONPATH=/app

RUN pip install --no-cache-dir \
    "libp2p>=0.3" \
    "fastapi>=0.115" \
    "uvicorn[standard]>=0.32" \
    "httpx>=0.27"

COPY desert/p2p /app/p2p
COPY desert/bootstrap_server /app/bootstrap_server

ENV DESERT_P2P_LISTEN_PORT=4001
ENV BOOTSTRAP_HTTP_PORT=8090

EXPOSE 8090
EXPOSE 4001

CMD ["uvicorn", "bootstrap_server.main:app", "--host", "0.0.0.0", "--port", "8090"]
